qty=1 identified buc=buc_unknown -> an amulet of reflection
qty=1 unidentified -> a triangular amulet
qty=1 called=lifesave? -> an amulet called lifesave?
qty=3 identified buc=blessed -> 3 blessed amulet of reflections
qty=3 identified buc=uncursed -> 3 uncursed amulet of reflections
qty=3 identified buc=cursed -> 3 cursed amulet of reflections
